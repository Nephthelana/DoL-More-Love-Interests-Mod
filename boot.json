{
  "name": "More Love Interests Mod",
  "version": "0.1.7.0",
  "styleFileList": [
    "module/css/moreLoveInterests.css"
  ],
  "scriptFileList": [
    "game/More_Love_Interest_Mod_Collab.js",
    "game/More_Love_Interest_Mod_Drag.js"
  ],
  "tweeFileList": [
    "game/more_love_interest_box.twee",
    "game/more_love_interest_icon.twee",
    "game/more_love_interest_main.twee"
  ],
  "imgFileList": [],
  "addonPlugin": [
    {
      "modName": "TweeReplacer",
      "addonName": "TweeReplacerAddon",
      "modVersion": "1.0.0",
      "params": [
        {
          "passage": "Widgets Attitudes",
          "findString": "<<set _loveIntStart1 to $loveInterest.primary>>\n\t\t<<set _loveIntStart2 to $loveInterest.secondary>>\n\t\t<<set _loveIntStart3 to $loveInterest.tertiary>>\n\t\t<div id=\"loveInterest\" class=\"settingsToggleItem\">\n\t\t\t<div class=\"gold bold\">你认为谁是你的恋人？</div>\n\t\t\t<<loveInterest>>\n\t\t</div>\n\t\t<<loveInterestFunction>>",
          "replace": "<div class='settingsToggleItem'><<moreLoveInterest>></div>",
          "_comment": "删去原版的 主要/次要恋人 选项、恋人数量限制和终身伴侣特质效果，并新增模组的交互框"
        },
        {
          "passage": "Widgets",
          "findString": "/* Check if this is a main love interest */\n\t\t\t\tif (V.loveInterest.primary == T.npcData.nam) {\n\t\t\t\t\tT.loveInterest = true;\n\t\t\t\t} else if (V.loveInterest.secondary == T.npcData.nam) {\n\t\t\t\t\tT.loveInterest = true;\n\t\t\t\t} else if (V.loveInterest.tertiary == T.npcData.nam) {\n\t\t\t\t\tT.loveInterest = true;\n\t\t\t\t} else {\n\t\t\t\t\tT.loveInterest = false;\n\t\t\t\t}",
          "replace": "/* 重写这部分判定恋人的代码 */\n\t\t\t\tT.loveInterest = Object.values(V.loveInterest).includes(T.npcData.nam);",
          "_comment": "使设置为恋人的NPC在社交栏内显示恋人标记"
        },
        {
          "passage": "Widgets Attitudes",
          "findString": "<<widget \"loveInterestRemove\">>",
          "replace": "<<widget \"loveInterestRemove\">>\n\t<<set $loveInterestList.delete(_args[0])>>\n\t<<moreLoveInterestConfirm>>\n\t<<exit>>\n\t/* 以上为更多恋人模组改写放逐npc时的代码 */",
          "_comment": "放逐艾弗里、凯拉尔、惠特尼时，从恋人列表中清除对应npc"
        }
      ]
    },
    {
      "modName": "ReplacePatcher",
      "addonName": "ReplacePatcherAddon",
      "modVersion": "1.0.0",
      "params": {
        "js": [
          {
            "from": "V.loveInterest.secondary !== \"None\"",
            "to": "V.loveInterest.secondary !== \"None\" && false",
            "fileName": "time.js",
            "_comment": "取消原版意识等级降低/升高后，引起恋人数量变化的提示"
          },
          {
            "from": "V.loveInterestAwareMessage",
            "to": "V.loveInterestAwareMessage && false",
            "fileName": "time.js",
            "_comment": "取消原版意识等级降低/升高后，引起恋人数量变化的提示"
          }
        ]
      }
    }
  ],
  "dependenceInfo": [
    {
      "modName": "TweeReplacer",
      "version": ">=1.0.0"
    },
    {
      "modName": "ReplacePatcher",
      "version": "^1.0.0"
    },
    {
      "modName": "GameVersion",
      "version": ">=0.5.10.0"
    }
  ]
}